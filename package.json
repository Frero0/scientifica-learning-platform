{
  "name": "scientifica-learning-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "dotenv -e .env -- turbo dev",
    "build": "dotenv -e .env -- turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:api": "pnpm --filter @scientifica/api test",
    "test:unit": "pnpm --filter @scientifica/domain test",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,cjs,mjs,json,md,css,yml,yaml}\" && pnpm --filter @scientifica/db exec prisma format --schema prisma/schema.prisma",
    "db:generate": "dotenv -e .env -- pnpm --filter @scientifica/db prisma:generate",
    "db:migrate": "dotenv -e .env -- pnpm --filter @scientifica/db prisma:migrate",
    "db:migrate:dev": "dotenv -e .env -- pnpm --filter @scientifica/db prisma:migrate:dev",
    "db:seed": "dotenv -e .env -- pnpm --filter @scientifica/db prisma:seed",
    "db:studio": "dotenv -e .env -- pnpm --filter @scientifica/db prisma:studio"
  },
  "devDependencies": {
    "@scientifica/config": "workspace:*",
    "@types/node": "^20.17.10",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "dotenv-cli": "^7.4.4",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}
